# Salin file ini jadi ".env" lalu isi dengan kredensial Supabase kamu.
# Variabel EXPO_PUBLIC_* otomatis terbaca di runtime Expo.
# JANGAN taruh service-role / secret key di sini — hanya key publik (aman untuk client).

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Publishable key baru (Project Settings → API Keys), format `sb_publishable_…`.
# Nama lama EXPO_PUBLIC_SUPABASE_ANON_KEY (anon JWT `eyJ…`) juga masih dibaca.
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxxxxxxx

# OpenRouteService — untuk routing "hindari zona rawan" (avoid_polygons).
# Daftar gratis di https://openrouteservice.org/dev/#/signup lalu buat token.
# Tanpa ini, app pakai rute contoh (fallback) tapi algoritma skoring tetap jalan.
EXPO_PUBLIC_ORS_API_KEY=
